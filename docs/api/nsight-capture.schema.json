{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "nsight-capture",
  "description": "Capture GPU activity using NVIDIA Nsight Graphics",
  "type": "object",
  "properties": {
    "input": {
      "type": "object",
      "properties": {
        "Executable": { "type": "string", "description": "Executable to capture from" },
        "Activity": { "type": "string", "enum": ["FrameDebugger", "GPUTrace"], "description": "Capture activity type" },
        "OutputPath": { "type": "string", "description": "Output file path" },
        "Arguments": { "type": "string", "description": "Arguments for the executable" },
        "CaptureFrame": { "type": "integer", "description": "Frame number to capture" },
        "NgfxPath": { "type": "string", "description": "Path to ngfx.exe (auto-detected if omitted)" },
        "Timeout": { "type": "integer", "description": "Timeout in seconds (default: 120)" }
      },
      "required": ["Executable"]
    },
    "output": {
      "type": "object",
      "properties": {
        "success": { "type": "boolean" },
        "activity": { "type": "string" },
        "outputPath": { "type": "string" },
        "outputFiles": { "type": "array", "items": { "type": "string" } },
        "stdout": { "type": "string" },
        "stderr": { "type": "string" },
        "executable": { "type": "string" }
      },
      "required": ["success", "activity", "outputPath"]
    },
    "errors": {
      "type": "object",
      "properties": {
        "1": { "const": "Capture failed" }
      }
    }
  }
}
