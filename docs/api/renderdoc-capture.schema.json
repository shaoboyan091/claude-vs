{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "renderdoc-capture",
  "description": "Capture or replay graphics frames using RenderDoc",
  "type": "object",
  "properties": {
    "input": {
      "type": "object",
      "properties": {
        "Executable": { "type": "string", "description": "Executable to capture from" },
        "Pid": { "type": "integer", "description": "Running process to inject into" },
        "Replay": { "type": "string", "description": "Path to .rdc file to replay" },
        "OutputPath": { "type": "string", "description": "Output capture file path" },
        "CaptureFrame": { "type": "integer", "description": "Frame number to capture" },
        "CaptureDelay": { "type": "integer", "description": "Seconds to wait before capturing" },
        "Arguments": { "type": "string", "description": "Arguments for the executable" },
        "ExportTextures": { "type": "boolean", "description": "Export textures during replay" }
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "success": { "type": "boolean" },
        "mode": { "type": "string", "enum": ["capture", "inject", "replay"] },
        "outputPath": { "type": "string" },
        "stdout": { "type": "string" },
        "stderr": { "type": "string" }
      },
      "required": ["success", "mode", "outputPath"]
    },
    "errors": {
      "type": "object",
      "properties": {
        "1": { "const": "Capture or replay failed" }
      }
    }
  }
}
