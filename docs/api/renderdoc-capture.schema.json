{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "renderdoc-capture",
  "description": "Capture or replay graphics frames using RenderDoc",
  "type": "object",
  "properties": {
    "input": {
      "type": "object",
      "properties": {
        "Executable": { "type": "string", "description": "Executable to capture from" },
        "ProcessId": { "type": "integer", "description": "Running process to inject into" },
        "Replay": { "type": "string", "description": "Path to .rdc file to replay" },
        "OutputPath": { "type": "string", "description": "Output capture file path" },
        "CaptureFrame": { "type": "integer", "description": "Frame number to capture" },
        "CaptureDelay": { "type": "integer", "description": "Seconds to wait before capturing" },
        "Arguments": { "type": "string", "description": "Arguments for the executable" },
        "ExportTextures": { "type": "string", "description": "Directory to export textures to during replay" },
        "RenderDocPath": { "type": "string", "description": "Path to renderdoccmd.exe (auto-detected if omitted)" },
        "Timeout": { "type": "integer", "description": "Timeout in seconds (default: 120)" }
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "success": { "type": "boolean" },
        "mode": { "type": "string", "enum": ["launch-capture", "inject", "replay"] },
        "outputPath": { "type": "string" },
        "stdout": { "type": "string" },
        "stderr": { "type": "string" },
        "capture": { "type": "string", "description": "Replay file path (replay mode)" },
        "executable": { "type": "string", "description": "Executable path (launch-capture mode)" },
        "pid": { "type": "integer", "description": "Process ID (inject mode)" },
        "processName": { "type": "string", "description": "Process name (inject mode)" }
      },
      "required": ["success", "mode"]
    },
    "errors": {
      "type": "object",
      "properties": {
        "1": { "const": "Capture or replay failed" }
      }
    }
  }
}
