{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "pix-capture",
  "description": "Capture GPU frames using PIX",
  "type": "object",
  "properties": {
    "input": {
      "type": "object",
      "properties": {
        "Executable": { "type": "string", "description": "Executable to capture from" },
        "OutputPath": { "type": "string", "description": "Output .wpix file path" },
        "CaptureFrames": { "type": "integer", "description": "Number of frames to capture" },
        "Timeout": { "type": "integer", "description": "Timeout in seconds" },
        "PixInstallDir": { "type": "string", "description": "PIX installation directory" },
        "Arguments": { "type": "string", "description": "Arguments for the executable" }
      },
      "required": ["Executable"]
    },
    "output": {
      "type": "object",
      "properties": {
        "success": { "type": "boolean" },
        "outputPath": { "type": "string" },
        "captureExists": { "type": "boolean" },
        "pixDll": { "type": "string" },
        "frames": { "type": "integer" },
        "executable": { "type": "string" },
        "stdout": { "type": "string" },
        "stderr": { "type": "string" },
        "note": { "type": "string" }
      },
      "required": ["success", "outputPath", "captureExists"]
    },
    "errors": {
      "type": "object",
      "properties": {
        "1": { "const": "Capture failed" }
      }
    }
  }
}
