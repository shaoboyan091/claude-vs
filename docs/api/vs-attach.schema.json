{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "vs-attach",
  "description": "Attach Visual Studio debugger to a process or launch with debugging",
  "type": "object",
  "properties": {
    "input": {
      "type": "object",
      "properties": {
        "Pid": { "type": "integer", "description": "Process ID to attach to" },
        "Executable": { "type": "string", "description": "Executable to launch under debugger" },
        "Arguments": { "type": "string", "description": "Arguments for launched executable" },
        "VsVersion": { "type": "string", "description": "Visual Studio version (e.g. 2022, 2019)" }
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "success": { "type": "boolean" },
        "method": { "type": "string", "description": "attach or launch" },
        "pid": { "type": "integer" },
        "executable": { "type": "string" },
        "note": { "type": "string" }
      },
      "required": ["success", "method"]
    },
    "errors": {
      "type": "object",
      "properties": {
        "1": { "const": "Attach or launch failed" }
      }
    }
  }
}
